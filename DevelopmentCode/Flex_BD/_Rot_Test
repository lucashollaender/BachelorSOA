import numpy as np
import matplotlib.pyplot as plt
import matplotlib as mpl
from SOABody import SOABody
from MultibodySystem import MultibodySystem
from Simulation import Simulation
from Body_Properties import Joint, Rigid_Properties, Flex_Properties

# --- 1. Parameters (matching _TestFlex.py) ---
E, G, c, rho, n_nd, n_md = 230e9, 80e9, 0.2, 7850, 11, 10
w, h = 0.04, 0.06

# Both bodies aligned along positive x-axis
klOO1 = np.array([1, 0, 0]).reshape(3, 1)
klOO2 = np.array([1, 0, 0]).reshape(3, 1)

# Fixed hinges for both
H_type1 = "fixed"
H_type2 = "fixed"

# Mode selection as in _TestFlex.py
mode_selection = {"bending_xy": 2, "bending_xz": 2}

# --- 2. Build Bodies ---
j1 = Joint(klOO1, H_type1)
r1 = Rigid_Properties(rho, w, h)
f1 = Flex_Properties(E, G, c, n_nd, n_md, mode_selection=mode_selection)

j2 = Joint(klOO2, H_type2)
r2 = Rigid_Properties(rho, w, h)
f2 = Flex_Properties(E, G, c, n_nd, n_md, mode_selection=mode_selection)

b1 = SOABody(j1, r1, f1)
b2 = SOABody(j2, r2, f2)

# Apply downward load (-Z) on the tip of the second body
F_ext_tip = np.array([0, 0, 0, 0, 0, -1e3]).reshape(6, 1)
b1.set_F_ext(node=-1, F_ext=F_ext_tip)

# --- 3. Setup System & Simulation ---
bodies = [b1, b2]
system = MultibodySystem(bodies)
system.set_gravity(False)

tf = 3
dt = 0.01

sim = Simulation(system, tf, dt)
sim.set_max_step(0.01)

# --- 4. Integration ---
print("Running integration...")
sim.IntegrateSystem("Radau")
#sim.animate_nodes()

# --- 5. 2D Plotting (X-Z Plane) ---
# Extract nodal positions at the final time step
final_pos = sim.data.pos[-1] 
n_bodies = len(final_pos)

plt.figure(figsize=(10, 6))

# Match Simulation.py styling
cmap = mpl.colormaps['tab10']
colors = cmap(np.linspace(0, 1, n_bodies))

# Plot origin for reference
plt.plot([0], [0], 'o', color='gray', markersize=6)

for b_idx in range(n_bodies):
    body_nodes = final_pos[b_idx]

    # Extract X and Z coordinates for each node
    xs = [float(node[0][0]) for node in body_nodes]
    zs = [float(node[2][0]) for node in body_nodes]

    # Plot colored lines representing the beam links
    plt.plot(xs, zs, '-', lw=4, color=colors[b_idx], label=f'Body {b_idx + 1}')

    # Scatter plot for the nodes
    plt.plot(xs, zs, 'ko', markersize=4)

plt.title('Deformation (No End-Node-Rotation)', fontsize=20)
plt.xlabel('X (m)', fontsize=12)
plt.ylabel('Z (m)', fontsize=12)
plt.ylim(-0.02, 0.005)
plt.grid(True, linestyle='--', alpha=0.7)
plt.legend(fontsize=14)
#plt.axis('equal') # Prevents distortion of the bending shape
plt.show()